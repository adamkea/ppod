# Copy this file to `.env` and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API).
#
# These use the EXPO_PUBLIC_ prefix so they are inlined into the app bundle.
# The anon key is safe to ship in a client; row-level security is what
# actually protects the data.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
