# Copy this file to `.env` and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API).
#
# These use the EXPO_PUBLIC_ prefix so they are inlined into the app bundle.
# The anon key is safe to ship in a client; row-level security is what
# actually protects the data.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The public URL of your web deployment, used for email redirect links
# (e.g. password reset). Leave unset for mobile-only setups.
EXPO_PUBLIC_WEB_URL=https://your-app.vercel.app
